# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Required for editor login (HMAC auth)
SCHEDULE_APP_PASSWORD=
SCHEDULE_AUTH_SECRET=

# Required for schedule deletion
SCHEDULE_DELETE_PASSWORD=

# Google Places API key (reuse existing from index.html, scoped to this domain)
NEXT_PUBLIC_GOOGLE_PLACES_KEY=
